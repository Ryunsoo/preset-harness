{
  "preset": "design/minimal",
  "version": "0.1.0",

  "tokens": {
    "color": {
      "bg":         "#ffffff",
      "surface":    "#f8f9fa",
      "border":     "#e5e7eb",
      "text":       "#0f172a",
      "textMuted":  "#64748b",
      "accent":     "#0f172a",
      "accentText": "#ffffff",
      "danger":     "#dc2626",
      "success":    "#16a34a",
      "warning":    "#d97706"
    },
    "typography": {
      "family": {
        "sans": "Inter, system-ui, sans-serif",
        "mono": "ui-monospace, SFMono-Regular, monospace"
      },
      "size": {
        "xs": "12px", "sm": "14px", "base": "16px", "lg": "18px",
        "xl": "20px", "2xl": "24px", "3xl": "30px", "4xl": "36px"
      },
      "weight": { "regular": 400, "medium": 500, "semibold": 600 },
      "lineHeight": { "tight": 1.2, "normal": 1.5, "relaxed": 1.75 }
    },
    "spacing": {
      "1": "4px", "2": "8px", "3": "12px", "4": "16px",
      "6": "24px", "8": "32px", "12": "48px", "16": "64px", "24": "96px"
    },
    "radius": { "none": "0", "sm": "2px", "md": "4px", "lg": "8px", "full": "9999px" },
    "shadow": {
      "none": "none",
      "sm":   "0 1px 2px rgba(15, 23, 42, 0.05)",
      "md":   "0 2px 4px rgba(15, 23, 42, 0.06)"
    },
    "motion": {
      "durationFast": "120ms",
      "durationBase": "180ms",
      "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
    }
  },

  "components": {
    "button": {
      "radiusDefault": "md",
      "paddingXBySize": { "sm": "12px", "md": "16px", "lg": "24px" },
      "fontWeight": "medium"
    },
    "card": {
      "radiusDefault": "md",
      "border": "1px solid var(--color-border)",
      "shadowDefault": "none"
    }
  }
}

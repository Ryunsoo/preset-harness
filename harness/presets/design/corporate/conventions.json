{
  "preset": "design/corporate",
  "version": "0.1.0",

  "tokens": {
    "color": {
      "bg":         "#ffffff",
      "surface":    "#f1f5f9",
      "border":     "#cbd5e1",
      "text":       "#0b1220",
      "textMuted":  "#475569",
      "accent":     "#1e3a8a",
      "accentAlt":  "#1d4ed8",
      "accentText": "#ffffff",
      "danger":     "#b91c1c",
      "success":    "#15803d",
      "warning":    "#b45309"
    },
    "typography": {
      "family": {
        "sans": "'IBM Plex Sans', system-ui, sans-serif",
        "serif": "'IBM Plex Serif', Georgia, serif",
        "mono": "'IBM Plex Mono', ui-monospace, monospace"
      },
      "size": {
        "xs": "12px", "sm": "14px", "base": "16px", "lg": "18px",
        "xl": "20px", "2xl": "24px", "3xl": "32px", "4xl": "40px"
      },
      "weight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
      "lineHeight": { "tight": 1.25, "normal": 1.55, "relaxed": 1.75 }
    },
    "spacing": {
      "1": "4px", "2": "8px", "3": "12px", "4": "16px",
      "6": "24px", "8": "32px", "12": "48px", "16": "64px"
    },
    "radius": { "none": "0", "sm": "4px", "md": "6px", "lg": "8px", "full": "9999px" },
    "shadow": {
      "none": "none",
      "sm":   "0 1px 3px rgba(11, 18, 32, 0.08)",
      "md":   "0 4px 8px rgba(11, 18, 32, 0.1)",
      "lg":   "0 8px 16px rgba(11, 18, 32, 0.12)"
    },
    "motion": {
      "durationFast": "150ms",
      "durationBase": "220ms",
      "easing": "cubic-bezier(0.2, 0, 0.2, 1)"
    }
  },

  "components": {
    "button": {
      "radiusDefault": "sm",
      "paddingXBySize": { "sm": "12px", "md": "18px", "lg": "24px" },
      "fontWeight": "semibold"
    },
    "card": {
      "radiusDefault": "md",
      "border": "1px solid var(--color-border)",
      "shadowDefault": "sm"
    }
  }
}

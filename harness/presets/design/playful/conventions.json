{
  "preset": "design/playful",
  "version": "0.1.0",

  "tokens": {
    "color": {
      "bg":         "#fffaf5",
      "surface":    "#ffffff",
      "border":     "#f1e8e0",
      "text":       "#1f1235",
      "textMuted":  "#6b5e87",
      "accent":     "#ec4899",
      "accentAlt":  "#8b5cf6",
      "accentText": "#ffffff",
      "highlight":  "#facc15",
      "danger":     "#ef4444",
      "success":    "#10b981",
      "warning":    "#f59e0b"
    },
    "typography": {
      "family": {
        "sans": "Nunito, system-ui, sans-serif",
        "mono": "ui-monospace, SFMono-Regular, monospace"
      },
      "size": {
        "xs": "12px", "sm": "14px", "base": "16px", "lg": "18px",
        "xl": "22px", "2xl": "28px", "3xl": "36px", "4xl": "48px"
      },
      "weight": { "regular": 400, "semibold": 600, "bold": 700, "extrabold": 800 },
      "lineHeight": { "tight": 1.2, "normal": 1.55, "relaxed": 1.8 }
    },
    "spacing": {
      "1": "4px", "2": "8px", "3": "12px", "4": "16px",
      "6": "24px", "8": "32px", "12": "48px", "16": "72px", "24": "112px"
    },
    "radius": { "none": "0", "sm": "8px", "md": "12px", "lg": "20px", "xl": "28px", "full": "9999px" },
    "shadow": {
      "none": "none",
      "sm":   "0 4px 10px rgba(236, 72, 153, 0.12)",
      "md":   "0 10px 20px rgba(139, 92, 246, 0.15)",
      "lg":   "0 20px 40px rgba(31, 18, 53, 0.18)"
    },
    "motion": {
      "durationFast": "200ms",
      "durationBase": "280ms",
      "durationBounce": "380ms",
      "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    }
  },

  "components": {
    "button": {
      "radiusDefault": "full",
      "paddingXBySize": { "sm": "16px", "md": "22px", "lg": "28px" },
      "fontWeight": "bold"
    },
    "card": {
      "radiusDefault": "lg",
      "border": "none",
      "shadowDefault": "md"
    }
  }
}

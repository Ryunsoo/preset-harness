{
  "$schema": "https://example.invalid/preset-harness/conventions.schema.json",
  "preset": "react-ts",
  "version": "0.1.0",

  "runtime": {
    "node": ">=22",
    "packageManager": "pnpm@9"
  },

  "language": {
    "name": "typescript",
    "version": "5",
    "strict": true,
    "target": "ES2022",
    "moduleResolution": "bundler"
  },

  "framework": {
    "ui": "react@18",
    "router": "react-router-dom@6",
    "buildTool": "vite@5"
  },

  "stateManagement": {
    "client": "zustand",
    "server": "@tanstack/react-query@5",
    "form": "react-hook-form + zod"
  },

  "httpClient": {
    "base": "fetch",
    "wrapper": "examples/api-client.ts",
    "errorHandling": "throw-typed-error"
  },

  "styling": {
    "default": "css-modules",
    "optional": ["tailwindcss"]
  },

  "formatting": {
    "tool": "prettier",
    "config": {
      "printWidth": 100,
      "singleQuote": true,
      "semi": true,
      "trailingComma": "all",
      "arrowParens": "always"
    }
  },

  "linting": {
    "tool": "eslint",
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended",
      "plugin:react/recommended",
      "plugin:react-hooks/recommended"
    ],
    "importOrder": ["react", "external", "internal-alias(@/)", "relative"]
  },

  "naming": {
    "component": "PascalCase",
    "hook": "camelCase prefixed with 'use'",
    "store": "camelCase suffixed with 'Store'",
    "type": "PascalCase",
    "constant": "UPPER_SNAKE_CASE",
    "file": {
      "component": "PascalCase.tsx",
      "hook": "useXxx.ts",
      "util": "camelCase.ts",
      "type": "camelCase.types.ts",
      "test": "<source>.test.ts|tsx"
    }
  },

  "testing": {
    "unit": "vitest",
    "integration": "@testing-library/react",
    "e2e": "playwright",
    "coverage": {
      "minimum": 70,
      "excludes": ["**/*.test.*", "**/*.stories.*", "src/main.tsx"]
    }
  },

  "accessibility": {
    "minLevel": "WCAG 2.1 AA",
    "requireAltText": true,
    "requireLangAttribute": true
  }
}
